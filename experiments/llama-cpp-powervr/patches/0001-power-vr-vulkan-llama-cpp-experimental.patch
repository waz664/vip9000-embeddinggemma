From d4722260bda6ed26241408282aaea75450027307 Mon Sep 17 00:00:00 2001
From: Radxa GPU Experiment <radxa-gpu-experiment@users.noreply.github.com>
Date: Fri, 8 May 2026 21:43:14 +0000
Subject: [PATCH 1/2] vulkan: tolerate small shared memory devices

---
 ggml/src/ggml-vulkan/ggml-vulkan.cpp | 9 ++++++---
 1 file changed, 6 insertions(+), 3 deletions(-)

diff --git a/ggml/src/ggml-vulkan/ggml-vulkan.cpp b/ggml/src/ggml-vulkan/ggml-vulkan.cpp
index 0a7931002..a14dec597 100644
--- a/ggml/src/ggml-vulkan/ggml-vulkan.cpp
+++ b/ggml/src/ggml-vulkan/ggml-vulkan.cpp
@@ -3422,10 +3422,13 @@ static void ggml_vk_load_shaders(vk_device& device) {
             ggml_type t = (ggml_type)i;
             // Disable medium and large matrix multiplication if not enough shared memory is available
             // Check mmq warptiles as the largest configuration
-            // Throw an error if not enough for any matrix multiplication is available
+            // Some embedded GPUs expose very small compute shared memory. Keep
+            // the Vulkan backend usable for non-matmul ops instead of aborting
+            // device initialization; unsupported matmul types stay on CPU.
             if (!ggml_vk_matmul_shmem_support(device, s_warptile_mmq, false, t)) {
-                std::cerr << "ggml_vulkan: Error: Shared memory size too small for matrix multiplication." << std::endl;
-                throw std::runtime_error("Shared memory size too small for matrix multiplication.");
+                device->mul_mat_s[i] = false;
+                device->mul_mat_m[i] = false;
+                device->mul_mat_l[i] = false;
             } else if (!ggml_vk_matmul_shmem_support(device, m_warptile_mmq, false, t)) {
                 device->mul_mat_m[i] = false;
                 device->mul_mat_l[i] = false;
-- 
